{
  "extends": "../../packages/core/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@semafy/core": ["../../packages/core/src/index.ts"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/core/src/**/*"]
}
